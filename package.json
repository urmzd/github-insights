{
  "bin": {
    "github-insights": "dist-cli/index.js"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "commander": "^14.0.3",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.4",
    "smol-toml": "^1.6.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@vercel/ncc": "^0.38.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist-cli/"
  ],
  "license": "Apache-2.0",
  "name": "@urmzd/github-insights",
  "repository": {
    "type": "git",
    "url": "https://github.com/urmzd/github-insights.git"
  },
  "scripts": {
    "build": "bash scripts/build.sh",
    "ci": "npm run fmt && npm run lint && npm run typecheck && npm run test && npm run build",
    "fmt": "biome format src/",
    "fmt:fix": "biome check --fix src/",
    "generate": "GITHUB_TOKEN=$(gh auth token) GITHUB_REPOSITORY_OWNER=$(gh api user --jq .login) tsx --tsconfig tsconfig.cli.json src/cli.tsx",
    "lint": "biome check src/",
    "showcase": "teasr showme",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "version": "3.10.1"
}
