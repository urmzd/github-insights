# Enforce LF line endings for all text files
* text=auto eol=lf

# Ensure specific files use LF
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.rs text eol=lf
*.toml text eol=lf
*.go text eol=lf
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf

# Linguist overrides
dist/** linguist-generated
dist-cli/** linguist-generated
*.svg linguist-generated

# Markup / styling
*.html linguist-documentation
*.css linguist-documentation
*.md linguist-documentation

# Build tooling
Justfile linguist-vendored
justfile linguist-vendored

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
